{
  "name": "meow",
  "version": "1.0.0",
  "description": "Electron wrapper for Meow",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run web\" \"npm run tracker\"",
    "web": "cd meow_web && npm run dev",
    "app": "cd meow_app && npm run dev",
    "start-local": "node start-meow.js",
    "tracker": "cd tracker && node tracker.js",
    "electron": "electron .",
    "build-win": "electron-builder --win",
    "release": "powershell -ExecutionPolicy Bypass -File release.ps1"
  },
  "dependencies": {
    "active-win": "^8.2.1",
    "concurrently": "^9.2.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "meow-tracker": "file:./tracker",
    "wait-on": "^9.0.4",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "electron": "^41.5.2",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4"
  },
  "build": {
    "appId": "com.meow.app",
    "productName": "Meow",
    "directories": {
      "output": "meow_web/public/downloads"
    },
    "files": [
      "electron/**/*",
      "tracker/**/*",
      "package.json"
    ],
    "win": {
      "icon": "electron/Meow_logo.png",
      "target": [
        "portable"
      ]
    }
  }
}
