{
  "name": "meow",
  "version": "1.0.0",
  "description": "Electron wrapper for Meow",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently \"npm run web\" \"npm run tracker\"",
    "web": "cd meow_web && npm run dev",
    "app": "cd meow_app && npm run dev",
    "start-local": "node start-meow.js",
    "tracker": "cd tracker && node tracker.js",
    "electron": "electron ."
  },
  "dependencies": {
    "active-win": "^8.2.1",
    "concurrently": "^9.2.1",
    "electron": "^40.6.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "ws": "^8.19.0",
    "wait-on": "^9.0.4"
  },
  "devDependencies": {
    "tailwindcss": "^4",
    "@tailwindcss/postcss": "^4"
  },
  "build": {
    "appId": "com.meow.app",
    "productName": "Meow",
    "win": {
      "icon": "electron/Meow_logo.png"
    }
  }
}